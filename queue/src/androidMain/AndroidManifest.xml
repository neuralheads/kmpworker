<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        AndroidNetworkMonitor uses ConnectivityManager.registerNetworkCallback(),
        getActiveNetwork(), and getNetworkCapabilities() — all require this permission.
        Declaring it here merges it into the consuming app's manifest automatically.
    -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

</manifest>
