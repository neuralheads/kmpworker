gradlew        text eol=lf
gradlew.bat    text eol=crlf
*.sh           text eol=lf
*.kts          text eol=lf
*.kt           text eol=lf
*.gradle       text eol=lf
*.properties   text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.md           text eol=lf
*.json         text eol=lf
*.xml          text eol=lf