# Shell scripts - must have LF
gradlew        text eol=lf
gradlew.bat    text eol=crlf
*.sh           text eol=lf

# Source files - LF
*.kts          text eol=lf
*.kt           text eol=lf
*.gradle       text eol=lf
*.properties   text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.md           text eol=lf
*.json         text eol=lf
*.xml          text eol=lf
*.toml         text eol=lf
*.pro          text eol=lf
*.sq           text eol=lf

# Binary files - never touch line endings
*.jar          binary
*.aar          binary
*.png          binary
*.jpg          binary
*.ico          binary
*.zip          binary